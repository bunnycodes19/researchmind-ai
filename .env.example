# Database
POSTGRES_USER=researchmind
POSTGRES_PASSWORD=researchmind_secret
POSTGRES_DB=researchmind
DATABASE_URL=postgresql+asyncpg://researchmind:researchmind_secret@localhost:5432/researchmind

# JWT
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Google Gemini
GOOGLE_API_KEY=your-google-api-key

# App
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000
ENVIRONMENT=development

# Storage
UPLOAD_DIR=./data/uploads
FAISS_DIR=./data/faiss
MAX_UPLOAD_SIZE_MB=50
MAX_PAPERS_PER_USER=100

# Rate limiting
RATE_LIMIT_PER_MINUTE=60
